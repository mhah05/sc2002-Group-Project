@startuml
skinparam classAttributeIconSize 0

class Level {
    -levelNumber : int
    -difficulty : String
    -initialEnemies : List<Enemy>
    -backupEnemies : List<Enemy>
    +Level(levelNumber : int, difficulty : String)
    +getLevelNumber() : int
    +getDifficulty() : String
    +getInitialEnemies() : List<Enemy>
    +getBackupEnemies() : List<Enemy>
    +hasBackupSpawn() : boolean
}

class GameConfig {
    -selectedPlayer : Player
    -selectedLevel : Level
    -selectedItems : List<Item>
    +GameConfig(player : Player, level : Level, items : List<Item>)
    +getPlayer() : Player
    +getLevel() : Level
    +getItems() : List<Item>
}

Level <.. GameConfig
@enduml
